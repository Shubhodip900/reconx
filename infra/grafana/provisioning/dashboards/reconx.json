{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "End-to-end observability for the ReconX distributed reconciliation engine — ingestion, matching, resolution, and gateway.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Ingestion Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "sum by (source_system, status) (rate(reconx_ingestion_records_total[1m]))",
          "legendFormat": "{{source_system}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" },
            "spanNulls": false,
            "insertNulls": false,
            "barAlignment": 0
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 2,
      "title": "Ingestion Errors (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "sum by (source_system, status) (rate(reconx_ingestion_records_total{status=~\"failed|dlq\"}[1m]))",
          "legendFormat": "{{source_system}} / {{status}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "sum by (source_system, failure_reason) (rate(reconx_ingestion_validation_failures_total[1m]))",
          "legendFormat": "validation / {{failure_reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" },
            "spanNulls": false,
            "insertNulls": false,
            "barAlignment": 0
          },
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 3,
      "title": "Active Mismatches",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "reconx_engine_active_mismatches",
          "legendFormat": "Active Mismatches",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Engine Processing Latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "histogram_quantile(0.95, rate(reconx_engine_worker_cycle_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 worker cycle",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "histogram_quantile(0.50, rate(reconx_engine_worker_cycle_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 worker cycle",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 5,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "seconds",
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" },
            "spanNulls": false,
            "insertNulls": false,
            "barAlignment": 0
          },
          "unit": "s",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 5,
      "title": "Retry Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "reconx_resolution_retry_queue_depth",
          "legendFormat": "Pending Retries",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Retry Queue Exhausted",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "reconx_resolution_retry_queue_exhausted",
          "legendFormat": "Exhausted Entries",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "Auto-Resolutions / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "sum by (strategy, outcome) (rate(reconx_resolution_auto_resolutions_total[1m])) * 60",
          "legendFormat": "{{strategy}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "resolutions/min",
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" },
            "spanNulls": false,
            "insertNulls": false,
            "barAlignment": 0
          },
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 8,
      "title": "Gateway Request Rate by Route (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-reconx" },
          "expr": "sum by (method, path, status_code) (rate(reconx_gateway_http_requests_total[1m]))",
          "legendFormat": "{{method}} {{path}} ({{status_code}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" },
            "spanNulls": false,
            "insertNulls": false,
            "barAlignment": 0
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*5\\d\\d.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*4\\d\\d.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"] }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["reconx", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ReconX Overview",
  "uid": "reconx-overview",
  "version": 1
}
